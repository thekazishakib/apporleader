# ========================================
# ApoorLeader Environment Variables
# ========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to GitHub!

# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_PROJECT_ID=your_project_id_here
VITE_FIREBASE_APP_ID=your_app_id_here
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
VITE_FIREBASE_DATABASE_ID=your_firestore_database_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here

# Web3Forms
VITE_WEB3FORMS_ACCESS_KEY=your_web3forms_key_here

# Admin
VITE_ADMIN_EMAIL=your_admin_email@gmail.com

# Cloudinary
VITE_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset_name

# Cloudinary API (for server-side delete - Netlify only)
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here
